BRAIN_VIEW_URL=https://your-brain.example.com

# Protect the MCP endpoint. The initialization screen can generate this value.
BRAIN_MCP_SECRET=change-me

# Protect the web view. Prefer the generated hash over a plain text password.
BRAIN_VIEW_PASSWORD_HASH=sha256:salt:hash

# Optional: keep browser-origin MCP calls restricted.
ALLOWED_ORIGINS=https://chatgpt.com,https://claude.ai

# Optional: enable durable cloud storage on Vercel.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional alternative names for direct Upstash REST configuration.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
